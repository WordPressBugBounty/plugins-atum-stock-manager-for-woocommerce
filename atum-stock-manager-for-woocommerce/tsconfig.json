{
	"compilerOptions": {
		"baseUrl": ".",
		"lib": [ "es2020", "dom" ],
		"module": "esnext",
		"target": "es2020",
		"moduleResolution": "bundler",
		"sourceMap": true,
		"removeComments": true,
		"typeRoots": [ "./assets/js/src/types", "./node_modules/@types" ],
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"exclude": [
		"node_modules",
		"dist",
		"./assets/js/src/types",
		"./vendor"
	]
}
